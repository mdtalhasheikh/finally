# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Polygon.io API key for real market data
# If not set, the built-in market simulator is used (recommended for most users)
MASSIVE_API_KEY=

# Optional: Polling interval for Massive API in seconds (default 15)
MASSIVE_POLL_INTERVAL_SECONDS=15

# Optional: Override LLM fallback model
LLM_FALLBACK_MODEL=openrouter/google/gemini-2.5-flash

# Optional: Override SQLite database path (default /app/db/finally.db inside container)
# DB_PATH=/app/db/finally.db

# Optional: Set to "true" for deterministic mock LLM responses (for testing)
LLM_MOCK=false
