# Copy this file to .env and fill in your values.

# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Polygon.io (Massive) API key for real market data
# If not set, the built-in GBM market simulator is used (recommended for most users)
MASSIVE_API_KEY=

# Optional: Polling interval for Massive API (seconds). Default 15 (safe for free tier).
MASSIVE_POLL_INTERVAL_SECONDS=15

# Optional: Fallback LLM model if the primary model fails
LLM_FALLBACK_MODEL=openrouter/google/gemini-2.5-flash

# Optional: Set to "true" for deterministic mock LLM responses (E2E testing)
LLM_MOCK=false

# Optional: SQLite database file path. Default: /app/db/finally.db (Docker path)
# For local development outside Docker, set this to a local path:
# DB_PATH=./db/finally.db
